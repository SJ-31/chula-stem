import json
from datetime import date
from pathlib import Path


configfile: "env.yaml"


def add_root(file):
    root = config.get("root")
    if root:
        return f"{root}/{file}"
    return file


DATE = config.get("date", "no_date")

OUT = add_root(f"{config.get('output')}/{DATE}")

# * Variables set up

runs = {k: add_root(v) for k, v in config["bd_results"].items()}
samples = config["samples"]

refs_to_get, references = {}, {}
for ref, p in config["reference_files"].items():
    path = Path(add_root(p))
    adata_file = path.with_suffix(".h5ad")
    if not adata_file.exists():
        refs_to_get[ref] = adata_file
    references[ref] = adata_file

for n, db in config["query_reference"]["tcrmatch"].get("databases", {}).items():
    config["query_reference"]["tcrmatch"]["databases"][n] = add_root(db)

cell_annotation_results = {}
if config["annotate_cells"]["cellassign"]["run"]:
    cell_annotation_results.update(
        {
            "elbo_validation": f"{OUT}/cellassign/elbo_validation.png",
            "predictions_raw": f"{OUT}/cellassign/predictions_raw.csv",
            "predictions": f"{OUT}/cellassign/predictions.csv",
        }
    )

plots = {
    "top_clones": f"{OUT}/top_clones.csv",
    "expansion": f"{OUT}/plots/clone_expansion",
    "ct_abundance": f"{OUT}/plots/cell_type_abundance",
}
cohort_plots = {
    k: f"{OUT}/plots/{k}.png"
    for k in ["alpha_diversity", "public_private", "clone_ranks", "clone_cluster_ranks"]
}
plots.update(cohort_plots)

sequence_out = {
    "extracted": f"{OUT}/sequences/extracted",
    "stitchr": f"{OUT}/sequences/stitchr",
}
extracted_seqs = expand(
    "{o}/{s}{a}.fasta", o=sequence_out["extracted"], s=samples, a=["", "-aa"]
)
stitchr_seqs = expand(
    "{o}/{s}.fasta", o=sequence_out["stitchr"], s=samples
)  # TODO: add stitchr rule

q_outdir = f"{OUT}/reference_comparison"
query_results = {
    "scirpy": [
        *expand("{o}/scirpy/{r}_query.pkl", o=q_outdir, r=references.keys()),
        *expand("{o}/scirpy/{r}_query.csv", o=q_outdir, r=references.keys()),
    ],
    "tcrmatch": [
        *expand(
            "{o}/tcrmatch_{db}.csv",
            o=q_outdir,
            db=config["query_reference"]["tcrmatch"]["databases"],
        ),
        f"{q_outdir}/tcrmatch_invalid.csv",
    ],
}


# * Rules


rule all:
    input:
        *extracted_seqs,
        *query_results["scirpy"],
        *query_results["tcrmatch"],
        **refs_to_get,
        **cell_annotation_results,
        **plots,
        extracted_ignored=f"{sequence_out['extracted']}/ignored_sequences.csv",
        combined=f"{OUT}/combined.h5mu",


rule prepare_references:
    params:
        refs_to_get=refs_to_get,
    output:
        refs_to_get.values(),
    script:
        "prepare_data.py"


rule load_runs:
    output:
        f"{OUT}/combined.h5mu",
    params:
        runs=runs,
    script:
        "prepare_data.py"


rule annotate_cells:
    output:
        **cell_annotation_results,
    input:
        rules.load_runs.output,
    script:
        "prepare_data.py"


rule make_reports:
    input:
        rules.load_runs.output,
    params:
        plotdir=f"{OUT}/plots",
        outdir=f"{OUT}",
    output:
        **cohort_plots,
        top_clones=f"{OUT}/top_clones.csv",
        expansion=directory(f"{OUT}/plots/clone_expansion"),
        ct_abundance=directory(f"{OUT}/plots/cell_type_abundance"),
    script:
        "plotting.py"
        # TODO: add a rarefaction curve


# ** Full-length sequencing


rule extract_sequences:
    input:
        rules.load_runs.output,
    params:
        outdir=sequence_out["extracted"],
    output:
        extracted_seqs,
        ignored=rules.all.input.extracted_ignored,
    script:
        "analyses.py"


rule stitchr:
    input:
        rules.load_runs.output,
    run:
        import mudata as md
        import scirpy as ir

        arg_list = []
        species = config.get("stitchr", {}).pop("species", "HUMAN")
        for k, v in config("stitchr", {}).items():
            if isinstance(v, str) and len(v) > 1:
                arg_list.append(f"--{k} {v}")
            elif v:
                arg_list.append(f"--{k}")
                # args.append("")
                # args = " ".join(arg_list)

                # command_args = " ".join([f"--{k} {v}" for k, v in
                # thimble_command =
        shell("thimble ")


# ** Database querying


rule scirpy_query:
    input:
        rules.load_runs.output,
    params:
        references=references,
        outdir=f"{q_outdir}/scirpy",
    output:
        *query_results["scirpy"],
    script:
        "analyses.py"


rule tcrmatch:
    input:
        rules.load_runs.output,
    params:
        outdir=q_outdir,
    output:
        *query_results["tcrmatch"],
    script:
        "analyses.py"
