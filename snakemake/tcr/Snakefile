import json
from datetime import date
from pathlib import Path


configfile: "env.yaml"


TODAY = date.today().isoformat()
DATE = config.get("date", TODAY)

OUT = config.get("output")

runs = config["bd_results"]


refs_to_get = {}
for ref, p in config["reference_files"].items():
    path = Path(p)
    adata_file = path.parent.joinpath(f"{path.stem}.h5ad")
    if not adata_file.exists():
        refs_to_get[ref] = adata_file

cell_annotation_results = {}
if config["annotate_cells"]["cellassign"]:
    cell_annotation_results.update(
        {
            "elbo_validation": f"{OUT}/cellassign/elbo_validation.png",
            "predictions_raw": f"{OUT}/cellassign/predictions_raw.csv",
            "predictions": f"{OUT}/cellassign/predictions.csv",
        }
    )


rule all:
    input:
        **refs_to_get,
        **cell_annotation_results,
        combined_adata=f"{OUT}/combined.h5ad",


rule prepare_references:
    params:
        refs_to_get=refs_to_get,
    output:
        refs_to_get.values(),
    script:
        "prepare_data.py"


rule load_runs:
    output:
        f"{OUT}/combined.h5mu",
    script:
        "prepare_data.py"


rule annotate_cells:
    output:
        **cell_annotation_results,
    input:
        rules.load_runs.output,
    script:
        "prepare_data.py"


