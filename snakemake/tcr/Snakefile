import json
from datetime import date
from pathlib import Path


configfile: "env.yaml"


def add_root(file):
    root = config.get("root")
    if root:
        return f"{root}/{file}"
    return file


DATE = config.get("date", "no_date")

OUT = add_root(f"{config.get('output')}/{DATE}")

# * Variables set up

runs = {k: add_root(v) for k, v in config["bd_results"].items()}
samples = config["samples"]

REFS_TO_GET, REFERENCES = {}, {}


def add_to_refs(ref, path_str):
    path = Path(add_root(path_str))
    adata_file = path.with_suffix(".h5ad")
    if not adata_file.exists():
        REFS_TO_GET[ref] = adata_file
    REFERENCES[ref] = adata_file


for ref, p in config["reference_files"].items():
    if ref == "tcrdb":
        for pid, db_dir in p.items():
            add_to_refs(f"tcrdb_{pid}", db_dir)
    else:
        add_to_refs(ref, p)


for n, db in config["query_reference"]["tcrmatch"].get("databases", {}).items():
    config["query_reference"]["tcrmatch"]["databases"][n] = add_root(db)

cell_annotation_results = {}
if config["annotate_cells"]["cellassign"]["run"]:
    cell_annotation_results.update(
        {
            "elbo_validation": f"{OUT}/cellassign/elbo_validation.png",
            "predictions_raw": f"{OUT}/cellassign/predictions_raw.csv",
            "predictions": f"{OUT}/cellassign/predictions.csv",
        }
    )

plots = {
    "top_clones": f"{OUT}/top_clones.csv",
    "top_clusters": f"{OUT}/top_clusters.csv",
    "expansion": f"{OUT}/plots/clone_expansion",
    "ct_abundance": f"{OUT}/plots/cell_type_abundance",
}
cohort_plots = {
    k: f"{OUT}/plots/{k}.png"
    for k in [
        "alpha_diversity",
        "public_private",
        "clone_ranks",
        "clone_cluster_ranks",
        "public_private_clusters",
    ]
}
plots.update(cohort_plots)

sequence_out = {
    "extracted": f"{OUT}/sequences",
    "stitchr": f"{OUT}/sequences/stitchr",
}
extracted_seqs = expand(
    "{o}/{s}{a}.fasta", o=sequence_out["extracted"], s=samples, a=["", "-aa"]
)
chains = ("VJ_1", "VDJ_1")
vdj_plots = expand("{o}/plots/vdj/{s}/{c}", o=OUT, s=samples, c=chains)
vdj_alignments = expand("{o}/vdj_alignments/{s}/{c}", o=OUT, s=samples, c=chains)

q_outdir = f"{OUT}/reference_comparison"
query_results = {
    "scirpy": [
        r
        for r in [
            *expand("{o}/scirpy/scirpy_{r}.pkl", o=q_outdir, r=REFERENCES.keys()),
            *expand("{o}/scirpy/scirpy_{r}.csv", o=q_outdir, r=REFERENCES.keys()),
        ]
        if "tcrdb" not in r
    ],
    "tcrmatch": [
        *expand(
            "{o}/tcrmatch/tcrmatch_{db}.csv",
            o=q_outdir,
            db=config["query_reference"]["tcrmatch"]["databases"],
        ),
        f"{q_outdir}/tcrmatch/tcrmatch_invalid.csv",
    ],
    "compairr": [
        *expand("{o}/compairr/compairr_{db}.csv", o=q_outdir, db=REFERENCES.keys()),
        f"{q_outdir}/compairr/compairr_invalid.csv",
    ],
}

if clone_primers := config["create_primers"].get("wanted_clones"):
    primer_out = {
        "primers_tabular": f"{OUT}/fusion_primers.csv",
        "primers_json": f"{OUT}/.fusion_primers.json",
        "primers_tables": f"{OUT}/fusion_primers",
    }
else:
    primer_out = {}

if clone_constructs := config["create_primers"].get("wanted_clones"):
    constructs_out = {"construct_outdir": f"{OUT}/tcr_constructs"}
else:
    constructs_out = {}

# * Rules


rule all:
    input:
        *extracted_seqs,
        *query_results["scirpy"],
        *query_results["tcrmatch"],
        *query_results["compairr"],
        *vdj_plots,
        *vdj_alignments,
        **REFS_TO_GET,
        **constructs_out,
        **primer_out,
        **cell_annotation_results,
        **plots,
        mixtcr_all=f"{OUT}/mixtcrpred_results.csv",
        extracted_ignored=f"{sequence_out['extracted']}/ignored_sequences.csv",
        combined=f"{OUT}/combined.h5mu",


rule prepare_references:
    params:
        refs_to_get=REFS_TO_GET,
    output:
        REFS_TO_GET.values(),
    script:
        "scripts/prepare_data.py"


rule load_runs:
    output:
        f"{OUT}/combined.h5mu",
    params:
        runs=runs,
    script:
        "scripts/prepare_data.py"


rule annotate_cells:
    output:
        **cell_annotation_results,
    input:
        rules.load_runs.output,
    script:
        "scripts/prepare_data.py"


# ** Plots & Reports


rule make_reports:
    input:
        rules.load_runs.output,
    params:
        plotdir=f"{OUT}/plots",
        outdir=f"{OUT}",
    output:
        **cohort_plots,
        top_clones=f"{OUT}/top_clones.csv",
        top_clusters=f"{OUT}/top_clusters.csv",
        expansion=report(
            directory(f"{OUT}/plots/clone_expansion"),
            category="Clonal Expansion",
            patterns=["{sample}.png"],
            subcategory="Per sample",
            labels={"Sample": "{sample}"},
        ),
        ct_abundance=report(
            directory(f"{OUT}/plots/cell_type_abundance"),
            category="Cell type abundance",
            patterns=["{sample}.png"],
            labels={"Sample": "{sample}"},
        ),
    script:
        "scripts/plotting.py"
        # TODO: add a rarefaction curve


rule plot_sequence:
    input:
        rules.load_runs.output,
    params:
        plotdir=f"{OUT}/plots/vdj",
        outdir=f"{OUT}/vdj_alignments",
    output:
        *[
            report(
                directory(d),
                patterns=["cid{clone_id}-{index}_{chain}.png"],
                category="Chain alignment plots",
                subcategory=Path(d).parent.stem,
                labels={
                    "Chain type": Path(d).stem,
                    "Clone ID": "{clone_id}",
                    "Index": "{index}",
                    "Name": "{chain}",
                },
            )
            for d in vdj_plots
        ],
        *[directory(d) for d in vdj_alignments],
    script:
        "scripts/plotting.py"


# ** Full-length sequencing


rule extract_sequences:
    input:
        rules.load_runs.output,
    params:
        outdir=sequence_out["extracted"],
    output:
        extracted_seqs,
        ignored=rules.all.input.extracted_ignored,
    script:
        "scripts/analyses.py"


