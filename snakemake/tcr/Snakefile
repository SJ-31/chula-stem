        rules.load_runs.output,
    run:
        import mudata as md
        import scirpy as ir

        arg_list = []
        species = config.get("stitchr", {}).pop("species", "HUMAN")
        for k, v in config("stitchr", {}).items():
            if isinstance(v, str) and len(v) > 1:
                arg_list.append(f"--{k} {v}")
            elif v:
                arg_list.append(f"--{k}")
                # args.append("")
                # args = " ".join(arg_list)

                # command_args = " ".join([f"--{k} {v}" for k, v in
                # thimble_command =
        shell("thimble ")


rule mixtcrpred:
    input:
        rules.load_runs.output,
    params:
        outdir=f"{OUT}/mixtcrpred",
    output:
        rules.all.input["mixtcr_all"],
        *[
            temp(f)
            for f in expand(
                "{o}/{m}.csv", o=f"{OUT}/mixtcrpred", m=config["mixtcrpred"]["models"]
            )
        ],
    script:
        "scripts/mixtcr.py"


# ** Database querying


rule scirpy_query:
    input:
        *rules.prepare_references.output,
        rules.load_runs.output,
    params:
        references=REFERENCES,
        outdir=f"{q_outdir}/scirpy",
    output:
        *query_results["scirpy"],
    script:
        "scripts/analyses.py"


rule compairr:
    input:
        *rules.prepare_references.output,
        rules.load_runs.output,
    params:
        references=REFERENCES,
        outdir=f"{q_outdir}/compairr",
    output:
        *query_results["compairr"],
    script:
        "scripts/analyses.py"


rule tcrmatch:
    input:
        rules.load_runs.output,
    params:
        outdir=f"{q_outdir}/tcrmatch",
    output:
        *query_results["tcrmatch"],
    script:
        "scripts/analyses.py"


# ** Primers
rule create_primers:
    input:
        rules.load_runs.output,
    output:
        **{k: v for k, v in primer_out.items() if not k.endswith("tables")},
    script:
        "scripts/primers.py"


rule write_primer_tables:
    input:
        rules.create_primers.output.primers_json,
    params:
        outdir=f"{OUT}/fusion_primers",
    output:
        report(
            directory(f"{OUT}/fusion_primers"),
            category="Fusion primers",
            patterns=["cid{clone_id}_{sample}.{ext}"],
            labels={
                "Sample": "{sample}",
                "Clone ID": "{clone_id}",
                "File type": "{ext}",
            },
        ),
    script:
        "scripts/primer_table.R"


# ** TCR constructs
rule assemble_constructs:
    input:
        rules.load_runs.output,
    params:
        outdir=Path(f"{OUT}/tcr_constructs"),
    output:
        report(
            directory(f"{OUT}/tcr_constructs"),
            category="Constructs",
            patterns=["cid{clone_id}_{sample}.{ext}"],
            labels={
                "Sample": "{sample}",
                "Clone ID": "{clone_id}",
                "File type": "{ext}",
            },
        ),
        # BUG: these aren't showing up in the report
    script:
        "scripts/primers.py"
