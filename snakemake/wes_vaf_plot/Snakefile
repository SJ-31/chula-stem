configfile: "env.yaml"  # A config file must be provided


import pandas as pd
from datetime import date

TODAY = date.today().isoformat()
DATE = config.get("date", TODAY)

"""
Generate VAF figures from the results of the wes/wes_tumor_only pipeline

See env_template.yaml for what to specify
"""


outdir = f"{config['outdir']}/{DATE}"
data_path = config["root"]
sample_sheet = pd.read_csv(config["manifest"])
cohort = config.get("cohort", "cohort")
extra = config.get("extra", {})

cases = set(list(sample_sheet["patient"]) + extra.get("cases", []))

to_ignore = set()
for c in cases:
    if not Path(f"{data_path}/{c}/annotations/7-{c}-VEP_small.vcf.gz").exists():
        to_ignore.add(c)

print("Ignoring cases", to_ignore)
cases = list(cases - to_ignore)
vcf_dir = f"{outdir}/vcfs"
align_dir = f"{outdir}/alignments"


VAF_OUT = {
    "gene_metrics": f"{outdir}/gene_metrics.png",
    "vaf_separate": f"{outdir}/vaf_separate.png",
    "vaf": f"{outdir}/vaf.png",
    "plot_data": f"{outdir}/vaf_plot_data.tsv",
}
ALIGN_OUT = {"alignments": expand("{o}/{c}", o=align_dir, c=cases)}

if config.get("get_alignments"):
    print("Creating alignment plot only...")
    TARGETS = ALIGN_OUT
else:
    TARGETS = VAF_OUT


rule all:
    input:
        **TARGETS,


rule get_vep:  # Retrieve vep results for select genes
    output:
        tsvs=expand("{v}/{sample}.tsv", v=vcf_dir, sample=cases),
        vcfs=[temp(f) for f in expand("{v}/{sample}.vcf", v=vcf_dir, sample=cases)],
        combined=f"{vcf_dir}/combined.tsv",
    params:
        outdir=vcf_dir,
        cases=cases,
        data_path=data_path,
        genes=config["wanted_genes"],
    script:
        "select_genes.R"


rule get_sbs:  # Get single-base-substitution statistics
    params:
        data_path=data_path,
        cases=cases,
    output:
        f"{outdir}/sbs.tsv",
    script:
        "get_sbs.py"


multiqc_veps = [f"{data_path}/8-{cohort}-MultiQC_data/vep.txt"] + extra.get(
    "multiqc_vep", []
)


rule get_tmb:  # Retrieve tumor mutational burden counts
    input:
        multiqc_veps,
    output:
        f"{outdir}/tumor_mutational_burden.tsv",
    script:
        "get_tmb.R"


rule vaf_plot:  # Assemble plot
    input:
        combined_vep=rules.get_vep.output.combined,
        sbs=rules.get_sbs.output,
        tmb=rules.get_tmb.output,
    params:
        wanted_genes=config["wanted_genes"].keys(),
    output:
        gene_metrics=VAF_OUT["gene_metrics"],
        vaf_separate=VAF_OUT["vaf_separate"],
        vaf=VAF_OUT["vaf"],
        plot_data=VAF_OUT["plot_data"],
    script:
        "vaf_plot.R"


rule alignment_plot:
    input:
        vcfs=rules.get_vep.output.tsvs,
    output:
        plots=directory(expand("{o}/{c}", o=align_dir, c=cases)),
    params:
        outdir=align_dir,
        data_path=data_path,
    log:
        f"{align_dir}/alignment_plot.log",
    script:
        "alignment_plot.R"
