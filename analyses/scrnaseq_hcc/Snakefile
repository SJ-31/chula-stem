configfile: "cellranger_config.yaml"


combined_file = config["files"]["combined"]
permissive_features = config["files"]["permissive_features"]
passed_qc = config["files"]["passed_qc"]
logdir = config["logdir"]
outdir = config["outdir"]

from functions import provide_output_from_fs

gpu_res20 = {
    "mem": "50G",
    "qos": "gpu20gh",
    "gres": "gpu:3g.20gb:1",
    "slurm_partition": "gpu",
}
gpu_res40 = {
    "mem": "64G",
    "qos": "gpu40g",
    "gres": "gpu:7g.40gb:1",
    "slurm_partition": "gpu",
}

if config["test"]:
    gpu_res20 = {}
    gpu_res40 = {}

dr_use_cpu = {"umap", "t-sne"}

annotations = {
    "cellassign": {
        "predictions": f"{outdir}/cellassign_predictions.csv",
        "run_metrics": f"{outdir}/cellassign_metrics.csv",
    }
}
# if config["chosen_cluster_key"]:
# "anno_dotplot": [],

other_outs = {}
for fs_method in config["feature_selection"].keys():
    other_outs.update(provide_output_from_fs(fs_method, config))


rule all:
    input:
        passed_qc,
        permissive_features,
        f"{outdir}/qc",
        **annotations["cellassign"],
        **other_outs,


rule prepare_data:
    output:
        combined_file,
        permissive_features,
    script:
        "smk.py"


rule save_qc_plots:
    input:
        combined_file,
    output:
        directory(f"{outdir}/qc"),
    run:
        from functions import qc_plot_patient
        from pathlib import Path
        import anndata as ad

        outdir = Path(output[0])
        outdir.mkdir(exist_ok=True)

        combined = ad.read_h5ad(input[0])
        for patient in combined.obs["patient"].unique():
            qc_mads, mads_compare = qc_plot_patient(combined, patient)
            (qc_mads / mads_compare).save(outdir / f"{patient}.pdf")


# TODO: should also add doublet detection and removal
rule qc_filter:
    input:
        combined_file,
    output:
        passed=passed_qc,
        failed=config["files"]["failed_qc"],
    log:
        f"{logdir}/qc.log",
    run:
        import anndata as ad
        import scanpy as sc
        from functions import mads_filter_outliers

        combined = ad.read_h5ad(input[0])

        passed, failed = mads_filter_outliers(
            combined, filters=config["mads_thresholds"], reduction="all"
        )
        print("Original shape: {}".format(combined.shape))
        print("Shape of filtered: {}".format(passed.shape))
        print("Shape of failed: {}".format(failed.shape))
        passed.write_h5ad(output["passed"])
        failed.write_h5ad(output["failed"])


rule do_dimensionality_reduction:
    input:
        lambda wc: (
            other_outs[f"{wc.get('fs_name')}-{wc.get('integration')}"]
            if wc.get("integration") != "unintegrated"
            else passed_qc
        ),
    params:
        dr_method=lambda wc: wc.get("method"),
        integration_method=lambda wc: wc.get("integration"),
        hp_value=lambda wc: wc.get("val"),
    log:
        f"{logdir}/{{fs_name}}_DR_{{integration}}/{{method}}/{{method}}_{{val}}.log",
    resources:
        gres=lambda wc: None if wc.get("method") in dr_use_cpu else "gpu:7g.40gb:1",
        slurm_partition=lambda wc: "cpu" if wc.get("method") in dr_use_cpu else "gpu",
        mem=lambda wc: "80G" if wc.get("method") in dr_use_cpu else "64G",
        qos=lambda wc: "cpu24h" if wc.get("method") in dr_use_cpu else "gpu40g",
    output:
        f"{outdir}/{{fs_name}}/DR_{{integration}}/{{method}}/{{method}}_{{val}}.npy",
    script:
        "smk.py"


rule do_cfs:
    input:
        passed_qc,
    log:
        f"{logdir}/cfs/{{fs_name}}.log",
    output:
        similarity=f"{outdir}/{{fs_name}}/cfs/similarity.csv",
        communities=f"{outdir}/{{fs_name}}/cfs/communities.csv",
        ind_clustering=f"{outdir}/{{fs_name}}/cfs/ind_clustering.csv",
    script:
        "smk.R"


rule integrate:
    input:
        passed_qc,
    log:
        f"{logdir}/{{fs_name}}-integration_and_cluster_{{integration}}.log",
    params:
        feature_selection=lambda wc: wc.get("fs_name"),
        integration=lambda wc: wc.get("integration"),
    resources:
        **gpu_res20,
    output:
        f"{outdir}/{{fs_name}}/{{integration}}_integrated.h5ad",
    script:
        "smk.py"


rule cluster_cells:
    input:
        passed_qc,
        f"{outdir}/{{fs_name}}/{{integration}}_integrated.h5ad",
    params:
        integration=lambda wc: wc.get("integration"),
    output:
        f"{outdir}/{{fs_name}}/{{integration}}_clustering.h5ad",
    script:
        "smk.py"


rule mark_cluster_complete:
    input:
        expand(
            f"{outdir}/{{f}}/{{i}}_clustering.h5ad",
            f=feature_selection_methods,
            i=smk.config["integration"].keys(),
        ),
    output:
        f"{outdir}/.clustering_complete",
    shell:
        "touch {output}"


rule save_cluster_plots:
    input:
        passed_qc,
        f"{outdir}/{{fs_name}}/{{integration}}_clustering.h5ad",
    output:
        f"{outdir}/{{fs_name}}/{{integration}}_clustering.pdf",
    params:
        fs_name=lambda wc: wc.get("fs_name"),
        integration=lambda wc: wc.get("integration"),
    run:
        import anndata as ad
        import functions as fn

        adata = ad.read_h5ad(input[0])
        fn.make_cluster_dotplots(
            adata,
            filename=output[0],
            cluster_results=input[1],
            markers={},
            env=config,
        )


rule save_other_dotplots:
    input:
        **rules.do_cfs.output,
        **annotations["cellassign"],
        adata=passed_qc,
    params:
        feature_selection=lambda wc: wc.get("fs_name"),
    output:
        f"{outdir}/{{fs_name}}/dotplots.pdf",
        f"{outdir}/{{fs_name}}/cellassign_metrics.pdf",
    script:
        "smk.py"


# * Cell type annotation

# NOTE: don't need feature selection for cell assign because it will automatically
# subset features


rule cellassign:
    input:
        passed_qc,
    params:
        model=f"{outdir}/cellassign",
    resources:
        **gpu_res40,
    output:
        **annotations["cellassign"],
    script:
        "smk.py"


rule enrich_single_cell:
    input:
        passed_qc,
        f"{outdir}/.clustering_complete",
    output:
        f"{outdir}/annotations/gene_set_activity.csv",
        f"{outdir}/annotations/marker_gene_activity.csv",
    script:
        "smk.py"
