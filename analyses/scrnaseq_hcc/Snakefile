import pandas as pd


configfile: "cellranger_config.yaml"


combined_file = config["files"]["combined"]
passed_qc = config["files"]["passed_qc"]
logdir = config["logdir"]

GPU_RES = {
    "mem": "30G",
    "qos": "gpu20gh",
    "gres": "gpu:3g.20gb:1",
    "slurm_partition": "gpu",
}

dr_results = {}
for method, values in config[DR].items():
    vary_by = items["vary"][1]
    dr_results[f"dr_{method}"] = expand(
        f"{config['DR']['outdir']}/{method}/{method}_{{i}}.npy", i=vary_by
    )


rule all:
    input:
        **dr_results,
        passed_qc,


rule prepare_data:
    output:
        combined_file,
    script:
        "smk.py"


rule qc_filter:
    input:
        combined_file,
    output:
        passed=passed_qc,
        failed=config["files"]["failed_qc"],
        test=config["files"]["test"],
    log:
        f"{logdir}/qc.log",
    run:
        import anndata as ad
        import scanpy as sc
        from functions import mads_filter_outliers

        combined = ad.read_h5ad(input[0], backed=True)

        passed, failed = mads_filter_outliers(
            combined.to_memory(), filters=config["mads_thresholds"], reduction="all"
        )
        print("Original shape: {}".format(combined.shape))
        print("Shape of filtered: {}".format(filtered.shape))
        print("Shape of failed: {}".format(failed.shape))
        passed.write_h5ad(output["passed"])
        failed.write_h5ad(output["failed"])
        sc.pp.subsample(passed, fraction=0.1).write_h5ad(output["test"])


rule do_dimensionality_reduction:
    input:
        passed_qc,
    params:
        method=lambda wc: wc.get("method"),
        hp_value=lambda wc: wc.get("hp_value"),
    log:
        f"{logdir}/DR/{{method}}/{{method}}_{{val}}.log",
    resources:
        **GPU_RES,
    output:
        f"{config['DR']['outdir']}/{{method}}/{{method}}_{{val}}.npy",
    script:
        "smk.py"
