        passed_qc,
        features=lambda wc: permissive_features if wc.get("fs") == "default" else [],
    params:
        prefix=lambda wc: wc.get("fs"),
    output:
        f"{outdir}/.sample_clusters/{{fs}}.csv",
        f"{outdir}/.sample_clusters/{{fs}}_consensus.pdf",
    script:
        "smk.R"


rule gather_sample_clusters:
    input:
        clusters=expand(f"{outdir}/.sample_clusters/{{fs}}.csv", fs=sample_cluster_keys),
        plots=expand(
            f"{outdir}/.sample_clusters/{{fs}}_consensus.pdf", fs=sample_cluster_keys
        ),
        adata=passed_qc,
    output:
        f"{outdir}/sample_clusters.csv",
        f"{outdir}/sample_clusters_consensus.pdf",
    script:
        "smk.py"


rule do_de_samples:
    input:
        adata=passed_qc,
        features=permissive_features,
        clusters=f"{outdir}/sample_clusters.csv",
        model=lambda wc: (
            f"{outdir}/scVI_permissive"
            if config["do_de_samples"][wc.get("spec")].get("method") == "scVI"
            else []
        ),
    params:
        spec=lambda wc: wc.get("spec"),
    output:
        f"{anno_out}/.sample_de-{{spec}}.csv",
    script:
        "smk.py"


rule gather_de_samples:
    input:
        expand(
            f"{anno_out}/.sample_de-{{spec}}.csv",
            spec=config["do_de_samples"].keys(),
        ),
    output:
        f"{anno_out}/samples_de.csv",
    run:
        import pandas as pd

        tmp = []
        for csv in input:
            spec = Path(csv).stem.replace(".sample_de-", "")
            df = pd.read_csv(csv).assign(analysis_group=spec)
            if spec.startswith("edgeR") and "logFC" in df.columns:
                df.loc[:, "lfc"] = df["logFC"]
            elif spec.startswith("scVI"):
                if "lfc_median" in df.columns:
                    df.loc[:, "lfc"] = df["lfc_median"]
                if "contrast" not in df.columns:
                    df.loc[:, "contrast"] = df["analysis_group"].str.removeprefix(
                        "scVI_"
                    )
            tmp.append(df)
        pd.concat(tmp).to_csv(output[0], index=False)


