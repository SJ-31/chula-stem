rule save_cluster_plots:
    input:
        passed_qc,
        f"{outdir}/{{fs_name}}/{{integration}}_clustering.h5ad",
    output:
        f"{outdir}/{{fs_name}}/{{integration}}_clustering.pdf",
    params:
        fs_name=lambda wc: wc.get("fs_name"),
        integration=lambda wc: wc.get("integration"),
    run:
        import anndata as ad
        import functions as fn

        adata = ad.read_h5ad(input[0])
        fn.make_cluster_dotplots(
            adata,
            filename=output[0],
            cluster_results=input[1],
            markers={},
            env=config,
        )


rule save_qc_plots:
    input:
        combined_file,
    output:
        directory(f"{outdir}/qc"),
    run:
        from functions import qc_plot_patient
        from pathlib import Path
        import anndata as ad

        outdir = Path(output[0])
        outdir.mkdir(exist_ok=True)

        combined = ad.read_h5ad(input[0])
        for patient in combined.obs["patient"].unique():
            qc_mads, mads_compare = qc_plot_patient(combined, patient)
            (qc_mads / mads_compare).save(outdir / f"{patient}.pdf")


        """
Produces two plots
1. Regulatory networks provided by TFlink containing DE genes
2. Functional interaction networks from Reactome (excluding regulatory interactions)
    containing DE genes
"""


