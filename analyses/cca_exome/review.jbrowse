          "hgPbOk": 0,
          "sourceName": "GRCh38 Genome Reference Consortium Human Reference 38 (GCA_000001405.15)",
          "taxId": 9606,
          "id": "hg38",
          "name": "hg38",
          "accession": "hg38",
          "commonName": "Human",
          "jbrowseConfig": "https://jbrowse.org/ucsc/hg38/config.json",
          "jbrowseMinimalConfig": "https://jbrowse.org/ucsc/hg38/minimal.json"
        }
      },
