    {
      "type": "FeatureTrack",
      "trackId": "hg38-gnomadGenomesVariantsV3_1",
      "name": "gnomAD Variants - gnomAD v3.1",
      "assemblyNames": [
        "hg38"
      ],
      "description": "Genome Aggregation Database (gnomAD) Genome Variants v3.1",
