              "locationType": "UriLocation",
              "uri": "https://hgdownload.soe.ucsc.edu/gbdb/hg38/hoffmanMappability/k100.Umap.MultiTrackMappability.bw",
              "baseUri": "https://jbrowse.org/ucsc/hg38/config.json"
            },
            "source": "Umap M100"
          }
        ]
