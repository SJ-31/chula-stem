          "location": {
            "locationType": "UriLocation",
            "uri": "fishClones.bed.gz.csi",
            "baseUri": "https://jbrowse.org/ucsc/hg38/config.json"
          }
        }
      },
      "displays": [
        {
          "type": "LinearBasicDisplay",
          "displayId": "hg38-fishClones-LinearBasicDisplay"
        },
        {
          "type": "LinearArcDisplay",
          "displayId": "hg38-fishClones-LinearArcDisplay"
        }
