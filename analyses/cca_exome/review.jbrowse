    {
      "type": "FeatureTrack",
      "trackId": "hg38-hprcArrDupBedV1",
      "name": "Rearrangements - Duplications",
      "assemblyNames": [
        "hg38"
      ],
      "description": "Duplications with respect to hg38 in HPRC assemblies",
      "category": [
        "Human Pangenome"
      ],
