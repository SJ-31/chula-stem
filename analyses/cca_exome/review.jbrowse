          "type": "LinearBasicDisplay",
          "displayId": "hg38-nuMtSeq-LinearBasicDisplay"
        },
        {
          "type": "LinearArcDisplay",
          "displayId": "hg38-nuMtSeq-LinearArcDisplay"
        }
      ]
