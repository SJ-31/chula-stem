        "Variation and Repeats"
      ],
      "metadata": {
        "ucsc": {
          "bigDataUrl": "/gbdb/hg38/dgv/dgvGold.bb",
          "longLabel": "Database of Genomic Variants: Gold Standard Variants",
          "mouseOver": "<b>ID</b>: $name<br> <b>Position</b>: $chrom:${chromStart}-${chromEnd}<br> <b>CNV subtype</b>: $variant_sub_type<br> <b>Frequency</b>: $Frequency",
