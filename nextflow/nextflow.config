nextflow.enable.dsl=2
conda.enabled = true
conda.useMamba = true
singularity.enabled = true
resume = true

workDir = "/data/project/stemcell/shannc/.work"

params.addSuffix = { suffix, it -> [it[0] + ["suffix": suffix]] + it[1..-1] }
params.getId = { [it[0].id] + [it[1]] }
params.prependId = { [it[0].id] + it }
params.saveFn = { x -> x ==~ /.*\.log/ || !task.ext.publish ? null : x }
params.defaults = [
    "purity": 1,
    "ploidy": 2
]

process {
    conda = "/data/home/shannc/miniforge3" // Path to conda base
    // will be overwritten by process-specific ext directives
    ext.version = "UNSPECIFIED"
    ext.args = [""]
    ext.publish = true
    ext.cores = 1
    ext.threads = 1
}

// Use when running the complete pipeline
process {
    executor = "slurm"
    clusterOptions = "--qos=cpu24h"
    memory = "15 GB"
}
process {
    withLabel: "big_mem" {
        memory = "70 GB"
    }
    withLabel: "mid_mem" {
        memory = "40 GB"
    }
}

executor {
    queueSize = 10
    submitRateLimit = "10 sec"
}

params.reference_file = "$projectDir/config/EMPTY.nf"
params.ref = null
params.input = null // Input csv file
params.outdir = null // Root to output directory
params.routine = null
params.logdir = null

params.test_conf = null
if (params.test_conf != null) {
    includeConfig params.test_conf // Testing configuration should replace reference_file
} else {
    includeConfig params.reference_file // contains
    //  'params.ref', a map with reference data specific to the current routine
}
includeConfig params.tools // configuration for tools specific to the current routine
params.gatk_version = "4.6.1.0"
params.bcftools_version = "1.21"

env {
    PURECN = "/data/home/shannc/miniforge3/lib/R/library/PureCN/extdata"
}

params.configdir = "$projectDir/config"
if (params.input != null) {
    params.name = params.input.replaceAll(/.*\//, "").replaceAll(/\..*/, "")
} else {
    params.name = "UNSPECIFIED"
}
if (params.logdir == null) {
    params.logdir = "${params.outdir}/${params.name}-LOG"
}

params.source_name = "TOOL_SOURCE" // TODO: make this change after the initial run on everything is complete
params.source_description = "Tool producing call" // Description for the custom SOURCE tag

// Report pipeline metrics
def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
def rtitle = params.test_conf != null ? "test" : params.routine
report {
    enabled = true
    file = "${projectDir}/reports/${rtitle}_report-<${trace_timestamp}>.html"
    overwrite = true
}
trace {
    enabled = true
    file = "$projectDir/reports/${rtitle}_trace-<${trace_timestamp}>.tsv"
    overwrite = true
}
timeline {
    enabled = true
    file = "$projectDir/reports/${rtitle}_timeline-<${trace_timestamp}>.html"
    overwrite = true
}

// Print stuff on completion
workflow.onComplete = {
    println "Workflow complete"
    println "Success? $workflow.success"
    println "Duration: $workflow.duration"
}
