nextflow_process {

    name "Test Process CROSS_REFERENCE"
    script "modules/cross_reference.nf"
    process "CROSS_REFERENCE"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
            }
            process {
                """
                input[0] = [["out": "$params.out/cross_ref_rep",
                    "log": "$params.log/cross_ref_rep",
            ], "$params.out/msisensorpro_t/out.tsv"]
                input[1] = "MSI"
                input[2] = params.clingen_gene
                input[3] = params.msi_reference
                input[4] = 4
                """
            }
        }

        then {
            assert process.success
        }

    }

}
