nextflow_process {

    name "Test Process STRELKA2"
    script "modules/strelka2.nf"
    process "STRELKA2"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
            }
            process {
                """
                input[0] = [["out": "$params.out/strelka2",
                    "log": "$params.log/strelka2", "id": "sample2"],
                    "$params.out/bqsr/b_recal.bam",
                    "$params.out/bqsr/c_recal.bam",
                    ["$params.out/bqsr/c_recal.bai", "$params.out/bqsr/b_recal.bai"],
                    "$params.out/manta/4-candidateSmallIndels_Manta.vcf.gz"]
                input[1] = "$params.genome"
                input[2] = 4
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

}
