nextflow_process {

    name "Test Process DELLY"
    script "modules/delly.nf"
    process "DELLY"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
            }
            process {
                """
                input[0] = [["out": "$params.out/delly", "RGSM_normal": "10",
                    "log": "$params.log/delly", "id": "sample2"],
                    "$params.outdir/bqsr/b_recal.bam",
                    "$params.outdir/bqsr/c_recal.bam",
                    ["$params.out/bqsr/c_recal.bai", "$params.out/bqsr/b_recal.bai"]]
                input[1] = params.genome
                input[2] = ""
                input[3] = 4
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

}
