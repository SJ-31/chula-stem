nextflow_process {

    name "Test Process MSISENSORPRO"
    script "modules/msisensorpro.nf"
    process "MSISENSORPRO"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
            }
            process {
                """
                input[0] = (["out": "$params.out/msisensorpro",
                    "log:" "$params.log/msisensorpro", "id": "sample2"],
                    "$params.out/bqsr/b_recal.bam",
                    "$params.out/bqsr/c_recal.bam"
            )
                input[1] = "$params.genome"
                input[2] = "$params.homopoly"
                input[3] = 4
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

}
