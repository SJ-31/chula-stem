nextflow_process {

    name "Test Process MOSDEPTH"
    script "modules/mosdepth.nf"
    process "MOSDEPTH"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
            }
            process {
                """
                input[0] = [["out": "$params.out/mosdepth",
                        "log": "$params.log/mosdepth",
                    "id": "sample2",
                    "RGSM_normal": "10_blood",
                    "RGSM_tumor": "10_cancer"
                ],
                    "$params.out2/patient_10/normal/4-patient_10_normal-recal.bam",
                    "$params.out2/patient_10/normal/4-patient_10_normal-recal.bam.bai"]
                input[1] = params.targets
                input[2] = 3
                """
            }
        }

        then {
            assert process.success
        }

    }

}
