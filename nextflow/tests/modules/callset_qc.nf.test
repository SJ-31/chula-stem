nextflow_process {

    name "Test Process CALLSET_QC"
    script "modules/callset_qc.nf"
    process "CALLSET_QC"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
            }
            process {
                """
                input[0] = [["out": "$params.out/qc",
                        "log": "$params.log/qc",
                    "id": "sample2",
                    "RGSM_normal": "10_blood",
                    "RGSM_tumor": "10_cancer"
                ],
                    "/data/project/stemcell/shannc/tests/wes_test/standardize/5-null-Standardized.vcf.gz"]
                input[1] = ""
                input[2] = 3
                input[3] = 1000
                input[4] = ["PASS"]
                input[5] = 9
                """
            }
        }

        then {
            assert process.success
        }

    }

}
