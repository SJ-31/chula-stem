nextflow_process {

    name "Test Process CALLSET_QC"
    script "modules/callset_qc.nf"
    process "CALLSET_QC"

    test("Should run without failures") {

        when {
            params {
                load("$baseDir/tests/wes_params.yaml")
                ref = ["pon": "/data/project/stemcell/shannc/output/WES_PON/7-all_normals-PON.vcf.gz"]
            }
            process {
                """
                input[0] = [["out": "$params.out/qc",
                        "log": "$params.log/qc",
                    "id": "sample2",
                    "RGSM_normal": "10_blood",
                    "RGSM_tumor": "10_cancer"
                ],
                    "/data/project/stemcell/shannc/tests/wes_test/standardize/4-null-Standardized.vcf.gz"]
                qc = ["max_normal_depth": 3, "min_tumor_depth": 9,
                    "accepted_filters": ["PASS"]]
                input[1] = qc
                input[2] = 2
                """
            }
        }

        then {
            assert process.success
        }

    }

}
